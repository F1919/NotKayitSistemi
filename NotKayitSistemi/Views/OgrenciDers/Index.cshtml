@model IEnumerable<NotKayitSistemi.Models.Entities.OgrenciDers>

@{
    ViewData["Title"] = "Öğrenci Ders Listesi";
}

<h3>Öğrenci Ders Listesi</h3>

<a asp-action="Create" class="btn btn-success mb-3">
    Yeni Ders Ata
</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Öğrenci</th>
            <th>Ders</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @item.OgrenciTml?.Ad @item.OgrenciTml?.Soyad
                </td>

                <td>
                    @item.DersTml?.DersAd
                </td>

                <td>
                    <a asp-action="Details"
                       asp-route-id="@item.Id"
                       class="btn btn-info btn-sm">
                        Göster
                    </a>

                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-warning btn-sm">
                        Güncelle
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@item.Id"
                       class="btn btn-danger btn-sm">
                        Sil
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
