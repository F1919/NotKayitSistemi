@model List<NotKayitSistemi.Models.Entities.OgrenciTml>

@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .dashboard-header {
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        color: white;
        padding: 25px 30px;
        border-radius: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        border-radius: 18px;
        padding: 20px;
        color: white;
        box-shadow: 0 10px 20px rgba(0,0,0,.08);
    }

    .stat-blue {
        background: linear-gradient(135deg,#4e73df,#224abe);
    }

    .stat-green {
        background: linear-gradient(135deg,#1cc88a,#13855c);
    }

    .modern-table {
        background: white;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 10px 25px rgba(0,0,0,.05);
    }

        .modern-table thead {
            background: #1e1e2f;
            color: white;
        }

        .modern-table tbody tr {
            transition: 0.2s ease;
        }

            .modern-table tbody tr:hover {
                background: #f3f6ff;
                transform: scale(1.01);
            }

    .btn-modern {
        border-radius: 25px;
        padding: 4px 14px;
        font-size: .8rem;
    }

    .search-input {
        border-radius: 30px;
        padding-left: 15px;
    }
</style>

<!-- HEADER -->
<div class="dashboard-header d-flex justify-content-between align-items-center">

    <div>
        <h3 class="mb-1">🎓 Öğrenci Yönetim Paneli</h3>
        <small>Sistemde toplam <b>@Model.Count</b> öğrenci bulunmaktadır.</small>
    </div>

    <a asp-action="Create" class="btn btn-light btn-modern">
        + Yeni Öğrenci
    </a>

</div>


<!-- STATS -->
<div class="row mb-4">

    <div class="col-md-4">
        <div class="stat-card stat-blue">
            <h6>Toplam Öğrenci</h6>
            <h3>@Model.Count</h3>
        </div>
    </div>

    <div class="col-md-4">
        <div class="stat-card stat-green">
            <h6>Aktif Öğrenci</h6>
            <h3>@Model.Count</h3>
        </div>
    </div>

</div>


<!-- TABLE -->
<div class="modern-table p-4">

    <div class="row mb-3">
        <div class="col-md-9">
            <input id="searchInput"
                   class="form-control search-input"
                   placeholder="Öğrenci ara..." />
        </div>
        <div class="col-md-3 text-end">
            <button id="clearBtn"
                    class="btn btn-outline-secondary btn-modern">
                Temizle
            </button>
        </div>
    </div>

    <table class="table align-middle" id="ogrTable">
        <thead>
            <tr>
                <th>Ad Soyad</th>
                <th>Doğum Tarihi</th>
                <th class="text-end">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var o in Model)
            {
                <tr data-id="@o.Id">
                    <td>
                        <strong>@o.Ad @o.Soyad</strong><br />
                        <small class="text-muted">ID: @o.Id</small>
                    </td>

                    <td>@o.DogumTarihi.ToString("dd.MM.yyyy")</td>

                    <td class="text-end">

                        <a asp-action="Details"
                           asp-route-id="@o.Id"
                           class="btn btn-light btn-modern">
                            Göster
                        </a>

                        <a asp-action="Edit"
                           asp-route-id="@o.Id"
                           class="btn btn-warning btn-modern">
                            Düzenle
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@o.Id"
                           class="btn btn-danger btn-modern">
                            Sil
                        </a>

                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>