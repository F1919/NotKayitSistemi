@model NotKayitSistemi.Models.Entities.OgrenciTml

<h3>Öğrenci Düzenle</h3>
<hr />

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label>Ad</label>
        <input asp-for="Ad" class="form-control" />
    </div>

    <div class="form-group mt-3">
        <label>Soyad</label>
        <input asp-for="Soyad" class="form-control" />
    </div>

    <div class="form-group mt-3">
        <label>Doğum Tarihi</label>
        <input asp-for="DogumTarihi" type="date" class="form-control" />
    </div>

    <div class="form-group mt-3">
        <label>Cinsiyet</label>
        <input asp-for="Cinsiyet" class="form-control" />
    </div>

    <button type="submit" class="btn btn-warning mt-4">
        Güncelle
    </button>

    <a asp-action="Index" class="btn btn-secondary mt-4">
        Geri
    </a>
</form>
