@model NotKayitSistemi.Models.Entities.NotTml

<h3>Not Güncelle</h3>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label>Öğrenci</label>
        <select asp-for="OgrenciTmlId" class="form-control" asp-items="ViewBag.OgrenciTmlId"></select>
    </div>

    <div class="form-group mt-3">
        <label>Ders</label>
        <select asp-for="DersId" class="form-control" asp-items="ViewBag.DersId"></select>
    </div>

    <div class="form-group mt-3">
        <label>Not Türü</label>
        <select asp-for="NotKodTmlId" class="form-control" asp-items="ViewBag.NotKodTmlId"></select>
    </div>

    <div class="form-group mt-3">
        <label>Değer</label>
        <input asp-for="Deger" class="form-control" />
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-warning">Güncelle</button>
        <a asp-action="Index" class="btn btn-secondary">Geri</a>
    </div>
</form>