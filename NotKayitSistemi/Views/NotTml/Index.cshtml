@model IEnumerable<NotKayitSistemi.Models.Entities.NotTml>

<a asp-action="Create" class="btn btn-success mb-3">Yeni Not Gir</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Öğrenci</th>
            <th>Ders</th>
            <th>Not Türü</th>
            <th>Değer</th>
            <th style="width:180px;"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.OgrenciTml?.Ad</td>
                <td>@item.DersTml?.DersAd</td>
                <td>@item.NotKodTml?.Tur</td>
                <td>@item.Deger</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Güncelle</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>
