@model NotKayitSistemi.Models.Entities.NotTml

<h3>Not Gir</h3>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label>Öğrenci</label>
        <select asp-for="OgrenciTmlId" class="form-control" asp-items="ViewBag.OgrenciTmlId">
            <option value="">-- Öğrenci Seç --</option>
        </select>
    </div>

    <div class="form-group mt-3">
        <label>Ders</label>
        <select asp-for="DersId" class="form-control" asp-items="ViewBag.DersId">
            <option value="">-- Ders Seç --</option>
        </select>
    </div>

    <div class="form-group mt-3">
        <label>Not Türü</label>
        <select asp-for="NotKodTmlId" class="form-control" asp-items="ViewBag.NotKodTmlId">
            <option value="">-- Not Türü Seç --</option>
        </select>
    </div>

    <div class="form-group mt-3">
        <label>Değer</label>
        <input asp-for="Deger" class="form-control" />
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-success">Kaydet</button>
        <a asp-action="Index" class="btn btn-secondary">Geri</a>
    </div>
</form>
