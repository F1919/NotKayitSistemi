@model IEnumerable<NotKayitSistemi.Models.Entities.DersTml>

<h2>Ders Listesi</h2>

<a asp-action="Create" class="btn btn-success mb-3">Yeni Ders Ekle</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Ders Adı</th>
            <th>Kredi</th>
            <th>Alan Türü</th>
            <th style="width:180px;">İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.DersAd</td>
                <td>@item.KrediSayisi</td>
                <td>@item.DersAlanKodTml?.Tur</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Düzenle</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>
