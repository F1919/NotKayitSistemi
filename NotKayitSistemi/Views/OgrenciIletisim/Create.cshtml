@model NotKayitSistemi.Models.Entities.OgrenciIletisim

@{
    ViewData["Title"] = "Yeni İletişim Ekle";
}

<h2>Yeni İletişim Ekle</h2>

<form asp-action="Create" method="post">

    <div class="form-group">
        <label>Öğrenci</label>
        <select asp-for="OgrenciTmlId"
                class="form-control"
                asp-items="ViewBag.Ogrenciler">
            <option value="">-- Öğrenci Seç --</option>
        </select>
        <span asp-validation-for="OgrenciTmlId" class="text-danger"></span>
    </div>

    <div class="form-group mt-3">
        <label>Email</label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="form-group mt-3">
        <label>Telefon</label>
        <input asp-for="Telefon" class="form-control" />
        <span asp-validation-for="Telefon" class="text-danger"></span>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-success">Kaydet</button>
        <a asp-action="Index" class="btn btn-secondary">Geri</a>
    </div>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}