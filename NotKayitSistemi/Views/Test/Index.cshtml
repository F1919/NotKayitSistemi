@model List<NotKayitSistemi.Models.AppUser>

<h2>Kullanıcılar</h2>

<table border="1">
    <tr>
        <th>Id</th>
        <th>Username</th>
        <th>Password</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Username</td>
            <td>@item.Password</td>
        </tr>
    }
</table>