@model NotKayitSistemi.Models.Entities.NotKodTml

<h2>Not Türü Güncelle</h2>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-3">
        <label asp-for="Tur" class="form-label"></label>
        <input asp-for="Tur" class="form-control" />
        <span asp-validation-for="Tur" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-warning">Güncelle</button>
    <a asp-action="Index" class="btn btn-secondary">Geri</a>

</form>
