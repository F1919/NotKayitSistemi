@model NotKayitSistemi.Models.Entities.DersAlanKodTml

<h2>Yeni Alan Türü Ekle</h2>

<form asp-action="Create" method="post">

    <div class="form-group mb-3">
        <label asp-for="Tur" class="form-label"></label>
        <input asp-for="Tur" class="form-control" />
        <span asp-validation-for="Tur" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Kaydet</button>
    <a asp-action="Index" class="btn btn-secondary">Geri</a>

</form>
