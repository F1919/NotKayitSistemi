@model IEnumerable<NotKayitSistemi.Models.Entities.OgrenciAdres>

<h2 class="mb-3">📍 Öğrenci Adres Listesi</h2>

<a asp-controller="OgrenciAdres"
   asp-action="Create"
   class="btn btn-primary mb-3">
    ➕ Yeni Adres
</a>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Öğrenci</th>
            <th>Adres</th>
            <th style="width:180px;">İşlem</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.OgrenciTml?.Ad @item.OgrenciTml?.Soyad</td>
                <td>@item.Adres</td>
                <td>
                    <a asp-controller="OgrenciAdres"
                       asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-warning btn-sm">
                        ✏ Düzenle
                    </a>

                    <a asp-controller="OgrenciAdres"
                       asp-action="Delete"
                       asp-route-id="@item.Id"
                       class="btn btn-danger btn-sm">
                        🗑 Sil
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
