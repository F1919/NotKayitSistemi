@model NotKayitSistemi.Models.Entities.OgrenciAdres

<h2>Yeni Adres Ekle</h2>

<form asp-action="Create">

    <div class="form-group">
        <label>Öğrenci</label>
        
        <select asp-for="OgrenciTmlId"
        asp-items="ViewBag.Ogrenciler"
        class="form-control">
      

          
        </select>
    </div>

    <div class="form-group">
        <label>Adres</label>
        <input asp-for="Adres" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Kaydet</button>
</form>
